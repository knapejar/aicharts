{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/chart.ts": {
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": "basemaps/**"
    },
    "api/mcp.ts": {
      "memory": 1024,
      "maxDuration": 60,
      "includeFiles": "basemaps/**"
    },
    "api/agent-guide.ts": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/chart", "destination": "/api/chart" },
    { "source": "/mcp", "destination": "/api/mcp" },
    { "source": "/llm.md", "destination": "/api/agent-guide" },
    { "source": "/agents", "destination": "/api/agent-guide" },
    { "source": "/agent-guide", "destination": "/api/agent-guide" },
    { "source": "/ai", "destination": "/api/agent-guide" }
  ],
  "headers": [
    {
      "source": "/chart",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" },
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    },
    {
      "source": "/mcp",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Mcp-Session-Id" }
      ]
    },
    {
      "source": "/(llm.md|agents|agent-guide|ai)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
